# ---- apps/api environment ----

# Server
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed CORS origins (web + expo dev).
# Note: apps/web falls back to :3001 when :3000 is taken (e.g. by Grafana),
# so both ports are allow-listed here.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081

# Postgres (Railway provides these). DIRECT_URL is used by Prisma migrations.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/crm?schema=public

# Redis (Railway provides REDIS_URL). Used by BullMQ (reminder engine) + health.
REDIS_URL=redis://localhost:6379

# ---- Milestone 3: reminders + notifications ----
# Reminder sweep cadence (ms) and send-worker concurrency (throttles storms).
REMINDER_SWEEP_INTERVAL_MS=60000
REMINDER_SEND_CONCURRENCY=10
# Email channel. If RESEND_API_KEY is set, reminder emails send via the Resend
# HTTP API; otherwise they are logged (dev-friendly, no external dep).
EMAIL_FROM=CRM <no-reply@crm.local>
RESEND_API_KEY=
# Optional Expo access token for authenticated push (recommended in prod).
EXPO_ACCESS_TOKEN=

# ---- Milestone 5: telephony (MyOperator) + recordings (Cloudinary) ----
# Active provider. Default 'mock' runs the ENTIRE pipeline from fixtures with NO
# account. Switch to 'myoperator' (and fill the credentials below) to go live —
# that + registering the webhook URL is the ONLY change needed. 'exotel' also
# supported.
TELEPHONY_PROVIDER=mock
# Reconciliation sweep cadence (ms) — re-pulls recent calls to fill MISSED
# webhooks. Default 5 min.
TELEPHONY_RECONCILE_INTERVAL_MS=300000
# Mock provider (default). HMAC secret the mock verifies webhooks against; the
# mock's outbound caller-id/DID. No real dialing.
MOCK_WEBHOOK_SECRET=mock-webhook-secret
MOCK_CALLER_ID=+911100000000

# Leave MYOPERATOR_API_TOKEN empty to run the adapter in MOCK mode (no real
# dialing; click-to-call still logs a Call with a generated id).
MYOPERATOR_API_URL=https://obd-api.myoperator.co
MYOPERATOR_API_TOKEN=
MYOPERATOR_COMPANY_ID=
# The org's caller-id / DID used as the "from" leg of click-to-call.
MYOPERATOR_CALLER_ID=+911140001234
# Shared secret for HMAC-SHA256 webhook verification. When set, bad signatures
# are rejected; when empty (dev) webhooks are accepted with a warning.
MYOPERATOR_WEBHOOK_SECRET=
# Register this webhook URL in the MyOperator dashboard:
#   https://<your-api-host>/api/v1/webhooks/myoperator
# The org is resolved by mapping the payload company_id → Organization.myoperatorCompanyId.

# Cloudinary — leave empty to run in MOCK mode (no real upload/signing).
# Provision the account/sub-account in INDIA for DPDP data residency.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=crm/recordings
RECORDING_MAX_BYTES=52428800
RECORDING_URL_TTL_SECONDS=300

# ---- Commerce ingestion (Shopify) ----
# Pinned Admin API version (bump deliberately).
SHOPIFY_API_VERSION=2024-10
# Auth model: client-credentials grant (post-Jan-2026 Dev Dashboard app). The app
# fetches + caches + auto-refreshes a ~24h Admin API token itself — NOTHING to paste.
#   SHOPIFY_API_KEY    = Client ID
#   SHOPIFY_API_SECRET = Client Secret   (also signs webhook HMAC)
#   SHOPIFY_WEBHOOK_SECRET = same Client Secret (or a dedicated webhook secret)
# The app + store MUST be in the SAME organization or the grant returns shop_not_permitted.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SHOP_DOMAIN=nerige.myshopify.com
# DEPRECATED — no longer used (token is fetched via client-credentials). Leaving a
# value here is harmless; it is ignored. Safe to delete.
SHOPIFY_ADMIN_ACCESS_TOKEN=
# Nightly reconciliation cadence (ms). Default 24h.
RECONCILE_INTERVAL_MS=86400000
# Register this webhook URL in Shopify (Admin → Notifications, or programmatically):
#   https://<your-api-host>/api/v1/webhooks/shopify
# Topics: orders/create|updated|paid|cancelled, refunds/create, customers/create|update,
#         checkouts/create|update. The org is resolved via X-Shopify-Shop-Domain →
#         Integration.config.shopDomain.

# Clerk (from the Clerk dashboard → API Keys)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Optional: PEM public key for networkless JWT verification (recommended in prod).
# WARNING: a PEM is multi-line, but .env values are single-line — pasting the raw
# key here truncates it to "-----BEGIN PUBLIC KEY-----" and every token fails with
# "token-invalid-signature". Either leave this EMPTY (the API then verifies via
# JWKS fetched with CLERK_SECRET_KEY) or put it on ONE line with literal \n escapes.
CLERK_JWT_KEY=
# Optional: restrict which frontends may present tokens (azp claim check).
# Must include the web origin — :3001 too, since apps/web falls back to it.
# NOTE: a missing origin here surfaces as a generic "Invalid or expired token".
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,http://localhost:3001,http://localhost:8081
# Clock-skew tolerance (ms) for JWT exp/nbf checks (default 5000).
CLERK_CLOCK_SKEW_MS=5000

# Seed identity — set these to a real Clerk user/org id after first sign-in so the
# seeded org maps to your Clerk account (see README "Seeding" section).
SEED_CLERK_ORG_ID=
SEED_CLERK_USER_ID=
SEED_USER_EMAIL=owner@example.com

# ---- Cart recovery (M4) ----
# A cart is "abandoned" after this many minutes without conversion.
ABANDONED_CART_THRESHOLD_MINUTES=60
# Sweep cadences (ms): enrollment (find carts) + send (fire due steps).
CAMPAIGN_ENROLL_INTERVAL_MS=300000
CAMPAIGN_SEND_INTERVAL_MS=120000
# Email channel via Resend. Unset RESEND_API_KEY => MOCK mode (logs + synthetic
# id; the loop still runs). RESEND_API_KEY + EMAIL_FROM are shared with M3.
# Register the Resend webhook: https://<api-host>/api/v1/webhooks/resend
# When set, webhooks must carry a matching HMAC in the `resend-signature` header.
RESEND_WEBHOOK_SECRET=
# Base URL + HMAC key for the signed unsubscribe link embedded in emails.
APP_BASE_URL=http://localhost:4000
UNSUBSCRIBE_SECRET=dev-unsubscribe-secret

# ---- PII protection (encryption at rest + match-hashes) ----
# Customer name/email/phone are encrypted at rest with AES-256-GCM. Provide REAL
# secrets from the vault in production (NEVER commit them). Leaving these at the
# insecure dev defaults logs a warning at boot.
# ENCRYPTION_KEY encrypts PII; keep it OUT of the database and rotate via the
# _PREVIOUS pair (old rows decrypt under the previous key until pii:backfill
# re-encrypts them under the new one).
ENCRYPTION_KEY=dev-only-insecure-encryption-key-change-me
ENCRYPTION_KEY_VERSION=1
# On rotation: move the old key here, bump ENCRYPTION_KEY(_VERSION), then run
# `pnpm --filter @crm/api pii:backfill` to re-encrypt under the new version.
ENCRYPTION_KEY_PREVIOUS=
ENCRYPTION_KEY_PREVIOUS_VERSION=
# HASH_PEPPER keys the deterministic HMAC-SHA256 match-hashes (email/phone) used
# for identity resolution + dedup. Store separately from the DB. Changing it
# invalidates every stored hash (re-run pii:backfill to recompute).
HASH_PEPPER=dev-only-insecure-hash-pepper-change-me
