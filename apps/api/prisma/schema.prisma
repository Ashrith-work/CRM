// CRM data model — Milestone 0 (foundation).
// Invariant: every table carries organizationId so all data is tenant-scoped.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id         String   @id @default(cuid())
  clerkOrgId String?  @unique
  name       String
  slug       String   @unique
  // Milestone 5 — maps an inbound MyOperator webhook (its company id) to this org.
  myoperatorCompanyId String? @unique
  // P2.1 analytics — IANA tz for revenue/cohort day-bucketing; hasCogs governs
  // whether contribution margin is real (COGS) or a labelled estimate.
  timezone   String   @default("Asia/Kolkata")
  hasCogs    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users           User[]
  teams           Team[]
  roles           Role[]
  permissions     Permission[]
  userRoles       UserRole[]
  teamMemberships TeamMembership[]
  auditLogs       AuditLog[]
  aiQueries       AiQuery[]

  // Milestone 1 — CRM data model.
  companies              Company[]
  contacts               Contact[]
  leads                  Lead[]
  tags                   Tag[]
  taggables              Taggable[]
  notes                  Note[]
  customFieldDefinitions CustomFieldDefinition[]
  activityEvents         ActivityEvent[]

  // Milestone 2 — revenue layer.
  pipelines      Pipeline[]
  stages         Stage[]
  deals          Deal[]
  stageHistories StageHistory[]

  // Milestone 3 — activity, reminders, notifications.
  tasks         Task[]
  reminders     Reminder[]
  notifications Notification[]
  pushTokens    PushToken[]

  // Milestone 5 — call management.
  calls    Call[]
  consents Consent[]

  // M0 retrofit — connected third-party integrations.
  integrations Integration[]

  // M1 — Shopify commerce ingestion.
  customers         Customer[]
  products          Product[]
  orders            Order[]
  orderItems        OrderItem[]
  carts             Cart[]
  cartItems         CartItem[]
  commerceEvents    CommerceEvent[]
  webhookDeliveries WebhookDelivery[]

  // M2 — Customer 360 (timeline pointer + denormalized features + export audit).
  interactions       Interaction[]
  customerFeatures   CustomerFeatures[]
  experienceExports  ExperienceExport[]

  // M3 — segmentation.
  segments           Segment[]
  segmentMemberships SegmentMembership[]

  // M4 — abandoned-cart recovery (the closed loop).
  campaigns           Campaign[]
  campaignEnrollments CampaignEnrollment[]
  campaignSends       CampaignSend[]
  messageTemplates    MessageTemplate[]
  suppressions        Suppression[]

  // P2.3 — Meta ads + attribution + audiences.
  adAccounts    AdAccount[]
  adCampaigns   AdCampaign[]
  adSets        AdSet[]
  ads           Ad[]
  adCreatives   AdCreative[]
  adMetrics     AdMetricDaily[]
  touchpoints   Touchpoint[]
  adLeads       AdLead[]
  audienceSyncs AudienceSync[]

  // Loyalty ledger + incentives.
  loyaltyTransactions LoyaltyTransaction[]
  incentives          Incentive[]

  @@index([slug])
}

/** Status of a connected third-party integration. */
enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PAUSED
}

/**
 * A third-party integration for an org (e.g. MYOPERATOR, CLOUDINARY, CLERK).
 * Stores only NON-SECRET config/metadata; secrets live in env/secret storage.
 */
model Integration {
  id                String            @id @default(cuid())
  organizationId    String
  provider          String
  status            IntegrationStatus @default(DISCONNECTED)
  externalAccountId String?
  config            Json              @default("{}")
  connectedById     String?
  connectedAt       DateTime?
  // M1 — last successful sync (backfill/reconciliation) for this integration.
  lastSyncedAt      DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId, deletedAt])
}

// ============================================================================
// Milestone 1 (commerce) — Shopify ingestion. Idempotency: UNIQUE(org,
// externalId) per entity + a WebhookDelivery dedup ledger. Money is INTEGER
// minor units (paise); all datetimes UTC. customerId/productId/mergedIntoId etc.
// are soft scalar refs (no cross-table FK web), matching the CRM convention.
// ============================================================================

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum FinancialStatus {
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
}

enum CommerceEventType {
  CHECKOUT_STARTED
  ADD_TO_CART
  ORDER_PLACED
}

model Customer {
  id             String    @id @default(cuid())
  organizationId String
  externalId     String? // Shopify customer id (guests may be null)
  email          String? // normalized: trim + lowercase
  phone          String? // normalized: E.164
  firstName      String?
  lastName       String?
  /** Non-null when this row was merged INTO another (survivor). */
  mergedIntoId   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId])
  @@unique([organizationId, email])
  @@index([organizationId, phone])
  @@index([organizationId, mergedIntoId])
}

model Product {
  id             String    @id @default(cuid())
  organizationId String
  externalId     String
  title          String
  imageUrl       String?
  /** P2.1 — per-unit COGS (paise) for real contribution margin; null ⇒ estimate. */
  costMinor      Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId])
}

model Order {
  id              String          @id @default(cuid())
  organizationId  String
  externalId      String
  orderNumber     String?
  customerId      String?
  status          OrderStatus     @default(PENDING)
  financialStatus FinancialStatus @default(PENDING)
  totalMinor      Int             @default(0)
  refundedMinor   Int             @default(0)
  currency        String          @default("INR")
  discountCode    String?
  discountMinor   Int             @default(0)
  /** P2.3 — first-touch attribution ride-along: landing UTMs + referrer from
   * Shopify cart attributes (note_attributes) / landing_site. Shape:
   * { utm: {source,medium,campaign,content,term}, landingSite, referringSite }. */
  attributes      Json?
  /** Denormalized first-touch source (from cart attributes) for cheap order-level
   * coverage %; "unknown" when UTMs were absent (never fabricated). */
  firstTouchSource String?
  placedAt        DateTime
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        OrderItem[]

  @@unique([organizationId, externalId])
  @@index([organizationId, customerId])
  @@index([organizationId, placedAt])
  @@index([organizationId, financialStatus])
  @@index([organizationId, firstTouchSource])
}

model OrderItem {
  id             String   @id @default(cuid())
  organizationId String
  orderId        String
  productId      String?
  title          String
  /** Apparel SIZE/COLOUR from the Shopify variant_title. */
  variant        String?
  quantity       Int      @default(1)
  priceMinor     Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([organizationId, orderId])
}

model Cart {
  id               String    @id @default(cuid())
  organizationId   String
  externalId       String // Shopify checkout token/id
  customerId       String?
  checkoutStartedAt DateTime
  /** Set when a matching Order arrives — halts M4 abandoned-cart recovery. */
  convertedOrderId String?
  /** P2.3 — first-touch UTM/referrer ride-along (same shape as Order.attributes). */
  attributes       Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        CartItem[]

  @@unique([organizationId, externalId])
  @@index([organizationId, customerId])
}

model CartItem {
  id             String   @id @default(cuid())
  organizationId String
  cartId         String
  productId      String?
  title          String
  variant        String?
  quantity       Int      @default(1)
  priceMinor     Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cart         Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([organizationId, cartId])
}

/** Behavioral stream (checkout_started / add_to_cart / order_placed) — feeds M4. */
model CommerceEvent {
  id             String            @id @default(cuid())
  organizationId String
  customerId     String?
  type           CommerceEventType
  externalId     String?
  metadata       Json?
  occurredAt     DateTime
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, customerId, occurredAt])
  @@index([organizationId, type, occurredAt])
}

/** Webhook dedup ledger — UNIQUE(org, provider, eventId) makes delivery idempotent. */
model WebhookDelivery {
  id             String   @id @default(cuid())
  organizationId String
  provider       String
  eventId        String
  topic          String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, eventId])
  @@index([organizationId, provider, createdAt])
}

// ============================================================================
// Milestone 2 — Customer 360. Interaction is a DENORMALIZED timeline pointer so
// the 360 timeline is ONE indexed query. CustomerFeatures denormalizes per-
// customer aggregates (+ placeholder RFM/CLV filled in M3) so the list + badges
// + fast profile avoid live aggregation. ExperienceExport audits every export.
// ============================================================================

enum InteractionType {
  ORDER
  EVENT
  MESSAGE
  CALL
  TICKET
  NOTE
  RETURN
  LEAD
}

model Interaction {
  id             String          @id @default(cuid())
  organizationId String
  customerId     String
  type           InteractionType
  /** Source row id (order id / event id / …). */
  refId          String
  summary        String?
  occurredAt     DateTime
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // The 360 timeline reads this in one indexed query (newest-first, type filter).
  @@index([organizationId, customerId, occurredAt])
  @@index([organizationId, customerId, type, occurredAt])
  @@unique([organizationId, type, refId])
}

model CustomerFeatures {
  id             String    @id @default(cuid())
  organizationId String
  customerId     String
  // Denormalized aggregates (net of refunds), maintained on ingest.
  netRevenueMinor    Int      @default(0)
  orderCount         Int      @default(0)
  firstOrderAt       DateTime?
  lastOrderAt        DateTime?
  avgOrderValueMinor Int      @default(0)
  currency           String?
  // RFM (written by the nightly refresh worker from the customer_rfm view).
  rScore        Int?
  fScore        Int?
  mScore        Int?
  /** Deterministic RFM segment label (e.g. "Champions", "At Risk"). */
  rSegment      String?
  rfmScore      String? // "R5 F4 M3" combined code (kept for display)
  daysSinceLast Int?
  // P2.1 — real CLV (historical net) + band, heuristic churn score + band.
  clvMinor      Int?
  clvBand       String? // High | Mid | Low
  churnRisk     Float?  // 0..1 heuristic score
  churnBand     String? // Low | Medium | High | Unknown
  /** VIP tier assigned by the tier worker from CLV (or spend fallback). */
  vipTier       String? // VIP | Gold | Silver | Standard
  apparelSize   String?
  fit           String?
  styleAffinity String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, customerId])
  @@index([organizationId, netRevenueMinor])
  @@index([organizationId, lastOrderAt])
  @@index([organizationId, rSegment])
}

model ExperienceExport {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String
  customerId     String?
  masked         Boolean
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

// ============================================================================
// Milestone 3 — segmentation. A Segment stores a JSON rule tree translated into
// a SAFE parameterized query over CustomerFeatures. STATIC snapshots membership
// at save; DYNAMIC recomputes it on a schedule. customer_rfm is a raw SQL
// MATERIALIZED VIEW (see the migration) — not modeled here.
// ============================================================================

enum SegmentType {
  STATIC
  DYNAMIC
}

model Segment {
  id              String      @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  /** JSON rule tree: { op: AND|OR, rules: [ {field,op,value} | nested ] }. */
  rules           Json
  type            SegmentType @default(STATIC)
  refreshCron     String?
  createdById     String
  memberCount     Int         @default(0)
  lastRefreshedAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      SegmentMembership[]

  @@index([organizationId, deletedAt])
}

model SegmentMembership {
  id             String   @id @default(cuid())
  organizationId String
  segmentId      String
  customerId     String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  segment      Segment      @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([segmentId, customerId])
  @@index([organizationId, segmentId])
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  clerkUserId    String   @unique
  email          String
  firstName      String?
  lastName       String?
  // Milestone 3 — IANA timezone so "9am" reminders fire at 9am THEIR local time.
  timezone       String   @default("UTC")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  teamMemberships TeamMembership[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships  TeamMembership[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Role {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  Permission[] @relation("RolePermissions")
  userRoles    UserRole[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Permission {
  id             String   @id @default(cuid())
  organizationId String
  key            String // e.g. "user:read" — see @crm/types PERMISSIONS
  description    String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roles        Role[]       @relation("RolePermissions")

  @@unique([organizationId, key])
  @@index([organizationId])
}

model UserRole {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([organizationId])
}

model TeamMembership {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  teamId         String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([organizationId])
}

model AuditLog {
  id               String   @id @default(cuid())
  organizationId   String
  actorUserId      String?
  actorClerkUserId String?
  action           String // e.g. "create", "update", "delete"
  entity           String // e.g. "Team", or the route path
  entityId         String?
  before           Json?
  after            Json?
  ip               String?
  userAgent        String?
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, createdAt])
}

// P2.2 — read-only AI assistant. One row per question: who asked, the question,
// which SAFE read-only tools ran (never SQL — there is none), and when. This is
// the assistant's own audit trail (the AuditInterceptor only logs mutations;
// asking is a read, so the assistant records it here explicitly). The assistant
// never returns data the asker's role couldn't otherwise see.
model AiQuery {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String
  question       String
  /** [{ tool, args, rowCount }] — the curated tools the orchestrator invoked. */
  toolsCalled    Json
  /** Whether the answer was served from cache (cost accounting). */
  cached         Boolean  @default(false)
  answeredAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, answeredAt])
  @@index([organizationId, actorUserId])
}

// ============================================================================
// Milestone 1 — CRM core data model.
// Invariant (unchanged): every table carries organizationId; all lists filter
// deletedAt = null. ownerId / authorId / actorId hold a User.id but are stored
// as plain scalars (soft references) to avoid a web of User back-relations.
// ============================================================================

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

/** First-class CRM entities that can carry tags, notes, custom fields, and
 * activity. DEAL added in Milestone 2. */
enum EntityType {
  CONTACT
  COMPANY
  LEAD
  DEAL
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
}

enum ActivityEventType {
  CREATED
  UPDATED
  NOTE_ADDED
  TAG_ADDED
  STATUS_CHANGED
  CONVERTED
  // Milestone 2 — deals.
  STAGE_CHANGED
  WON
  LOST
  REOPENED
  // Milestone 3 — activity tasks.
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_CANCELLED
  // Milestone 5 — calls.
  CALL_LOGGED
  CALL_COMPLETED
  CALL_MISSED
}

model Company {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  domain         String?
  industry       String?
  size           String?
  website        String?
  phone          String?
  addressJson    Json?
  ownerId        String?
  customFields   Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  deals        Deal[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, ownerId])
  @@index([organizationId, name])
}

model Contact {
  id             String    @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  jobTitle       String?
  companyId      String?
  ownerId        String?
  customFields   Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company            Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  // Leads that converted into this contact (see Lead.convertedContactId).
  convertedFromLeads Lead[]       @relation("LeadConvertedContact")
  deals              Deal[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, email])
  @@index([organizationId, ownerId])
  @@index([companyId])
}

model Lead {
  id                 String     @id @default(cuid())
  organizationId     String
  firstName          String
  lastName           String
  email              String?
  phone              String?
  source             String?
  status             LeadStatus @default(NEW)
  ownerId            String?
  convertedContactId String?
  /** P3.x — the commerce Customer this lead converted into (find-or-create by
   * email/phone via M1 identity resolution). Soft scalar ref (no FK). */
  convertedCustomerId String?
  /** Source attribution — the first Touchpoint that brought this lead in. */
  firstTouchTouchpointId String?
  customFields       Json       @default("{}")
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  convertedContact Contact?     @relation("LeadConvertedContact", fields: [convertedContactId], references: [id], onDelete: SetNull)

  @@index([organizationId, deletedAt])
  @@index([organizationId, status])
  @@index([organizationId, email])
  @@index([organizationId, ownerId])
}

model Tag {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  color          String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  taggables    Taggable[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

/** Join row assigning a Tag to an entity. Hard-deleted on untag (no deletedAt)
 * so the uniqueness constraint stays clean and re-tagging is always allowed. */
model Taggable {
  id             String     @id @default(cuid())
  organizationId String
  tagId          String
  entityType     EntityType
  entityId       String
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, entityType, entityId])
  @@index([organizationId, entityType, entityId])
}

model Note {
  id             String    @id @default(cuid())
  organizationId String
  entityType     EntityType
  entityId       String
  authorId       String
  body           String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, entityType, entityId, createdAt])
}

model CustomFieldDefinition {
  id             String          @id @default(cuid())
  organizationId String
  entityType     EntityType
  key            String
  label          String
  fieldType      CustomFieldType
  options        Json?
  required       Boolean         @default(false)
  order          Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, entityType, key])
  @@index([organizationId, entityType])
}

/** Append-only domain timeline. Distinct from AuditLog (infra audit): this is
 * the user-facing activity feed emitted by ActivityService.emit(). */
model ActivityEvent {
  id             String            @id @default(cuid())
  organizationId String
  entityType     EntityType
  entityId       String
  actorId        String?
  eventType      ActivityEventType
  metadata       Json?
  source         String?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, entityType, entityId, createdAt])
  // Milestone 4 — "activities logged" per actor in a period.
  @@index([organizationId, actorId, createdAt])
}

// ============================================================================
// Milestone 2 — revenue layer (Pipelines, Stages, Deals, Stage History).
// Money is stored as INTEGER minor units (amountMinor) + a currency code —
// never a float. Stage history is append-only.
// ============================================================================

enum StageType {
  OPEN
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
}

model Pipeline {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  isDefault      Boolean   @default(false)
  position       Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages       Stage[]
  deals        Deal[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, position])
}

model Stage {
  id             String    @id @default(cuid())
  organizationId String
  pipelineId     String
  name           String
  position       Int       @default(0)
  probability    Int       @default(0) // 0-100
  type           StageType @default(OPEN)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals        Deal[]

  @@index([organizationId, pipelineId, position])
}

model Deal {
  id                String     @id @default(cuid())
  organizationId    String
  name              String
  pipelineId        String
  stageId           String
  amountMinor       Int        @default(0) // money in minor units (e.g. paise/cents)
  currency          String     @default("USD")
  expectedCloseDate DateTime?
  ownerId           String?
  contactId         String?
  companyId         String?
  status            DealStatus @default(OPEN)
  closedAt          DateTime?
  customFields      Json       @default("{}")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage        Stage          @relation(fields: [stageId], references: [id])
  contact      Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company      Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  stageHistory StageHistory[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, pipelineId, stageId])
  @@index([organizationId, ownerId])
  @@index([organizationId, status])
  @@index([contactId])
  @@index([companyId])
  // Milestone 4 — dashboard aggregates: won/lost in a period; deals created.
  @@index([organizationId, status, closedAt])
  @@index([organizationId, createdAt])
}

/** Append-only record of every stage transition. fromStageId/toStageId are
 * stored as scalars so history survives stage deletion. */
model StageHistory {
  id                     String   @id @default(cuid())
  organizationId         String
  dealId                 String
  fromStageId            String?
  toStageId              String
  changedById            String
  changedAt              DateTime @default(now())
  secondsInPreviousStage Int?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deal         Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([organizationId, dealId, changedAt])
}

// ============================================================================
// Milestone 3 — activity tasks, reminders, notifications, push tokens.
// Invariant (unchanged): every table carries organizationId; all datetimes are
// UTC. assigneeId / createdById / userId hold a User.id as soft scalar refs
// (no FK) to keep User back-relations minimal, matching M1/M2.
// ============================================================================

enum TaskType {
  TASK
  FOLLOW_UP
  MEETING
  CALL
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ReminderStatus {
  SCHEDULED
  SENT
  CANCELLED
}

enum NotificationType {
  REMINDER
  ASSIGNMENT
  MENTION
  SYSTEM
}

enum PushPlatform {
  IOS
  ANDROID
}

/** A unified activity item: a to-do, follow-up, meeting, or call, optionally
 * linked to a CRM record via relatedType (EntityType) + relatedId. */
model Task {
  id             String       @id @default(cuid())
  organizationId String
  type           TaskType     @default(TASK)
  title          String
  description    String?
  status         TaskStatus   @default(OPEN)
  priority       TaskPriority @default(MEDIUM)
  dueAt          DateTime?
  startAt        DateTime? // meetings
  endAt          DateTime? // meetings
  location       String?
  meetingUrl     String?
  assigneeId     String
  createdById    String
  relatedType    EntityType?
  relatedId      String?
  completedAt    DateTime?
  outcome        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reminders    Reminder[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, assigneeId, status, dueAt])
  @@index([organizationId, relatedType, relatedId])
  @@index([organizationId, startAt])
  // Milestone 4 — "tasks completed" per assignee in a period.
  @@index([organizationId, assigneeId, completedAt])
}

/** One row per scheduled reminder (append-only). The reminder engine marks rows
 * SENT atomically and enqueues a send job keyed by the reminder id (idempotent). */
model Reminder {
  id             String         @id @default(cuid())
  organizationId String
  taskId         String
  remindAt       DateTime
  channels       String[] // IN_APP | EMAIL | PUSH
  status         ReminderStatus @default(SCHEDULED)
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Hot path for the 60s sweep: due & still SCHEDULED.
  @@index([status, remindAt])
  @@index([organizationId, taskId])
}

/** The durable in-app notification record. Fanned out across channels; the
 * in-app row always persists so an offline user sees it on next load. */
model Notification {
  id                String           @id @default(cuid())
  organizationId    String
  userId            String // recipient (User.id, soft ref)
  type              NotificationType
  title             String
  body              String
  relatedType       EntityType?
  relatedId         String?
  taskId            String? // deep-link to the source task, if any
  readAt            DateTime?
  deliveredChannels String[] // IN_APP | EMAIL | PUSH — each delivered exactly once
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, readAt])
  @@index([organizationId, userId, createdAt])
}

/** An Expo push token for a user's device. UNIQUE(token); pruned when Expo
 * reports DeviceNotRegistered. */
model PushToken {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  token          String       @unique
  platform       PushPlatform
  lastSeenAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
}

// ============================================================================
// Milestone 5 — call management (MyOperator telephony + Cloudinary recordings +
// DPDP consent). Idempotency: UNIQUE(organizationId, externalCallId). agentUserId
// / contactId / dealId are soft scalar refs (no FK), matching M1–M4.
// ============================================================================

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  RINGING
  IN_PROGRESS
  COMPLETED
  MISSED
  FAILED
  NO_ANSWER
}

enum RecordingStatus {
  NONE
  PENDING
  STORED
  BLOCKED
  FAILED
}

enum ConsentPurpose {
  CALL_RECORDING
  MARKETING
}

enum ConsentStatus {
  GRANTED
  WITHDRAWN
  NOT_CAPTURED
}

enum ConsentSource {
  IVR_DISCLOSURE
  EXPLICIT
  SHOPIFY
}

model Call {
  id             String        @id @default(cuid())
  organizationId String
  direction      CallDirection
  fromNumber     String
  toNumber       String
  agentUserId    String?
  contactId      String?
  dealId         String?
  status         CallStatus    @default(RINGING)
  startedAt      DateTime?
  answeredAt     DateTime?
  endedAt        DateTime?
  durationSeconds Int?
  disposition    String?
  notes          String?
  /** MyOperator's call id — the webhook idempotency key. */
  externalCallId String?
  /** True when the matched number resolved to >1 contact (picked most-recent). */
  ambiguousMatch Boolean       @default(false)
  /** Provider recording URL (internal; never served to clients). */
  recordingSourceUrl String?
  /** Cloudinary public id / secure URL once stored (served via a signed URL). */
  recordingStoredUrl String?
  recordingStatus RecordingStatus @default(NONE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Idempotency: a retried webhook for the same externalCallId upserts one row.
  @@unique([organizationId, externalCallId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, contactId, startedAt])
  @@index([organizationId, agentUserId, startedAt])
  @@index([organizationId, direction, startedAt])
}

/** DPDP call-recording consent per contact. One row per (contact, purpose). */
model Consent {
  id             String         @id @default(cuid())
  organizationId String
  /** Call-recording consent is contact-scoped; marketing consent is
   * customer-scoped (from Shopify accepts_marketing). Exactly one is set. */
  contactId      String?
  customerId     String?
  purpose        ConsentPurpose @default(CALL_RECORDING)
  status         ConsentStatus  @default(NOT_CAPTURED)
  source         ConsentSource?
  grantedAt      DateTime?
  withdrawnAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, contactId, purpose])
  @@unique([organizationId, customerId, purpose])
  @@index([organizationId, contactId])
  @@index([organizationId, customerId, purpose])
}

// ============================================================================
// Milestone 4 — abandoned-cart recovery (the first CLOSED LOOP / MVP ship line).
// A repeatable enrollment sweep finds abandoned carts; a repeatable send sweep
// fires due steps (T+1h/+24h/+72h), consent-gated, and HALTS on purchase. Money
// is paise; time UTC. Suppression + marketing Consent gate every send.
// ============================================================================

enum CampaignType {
  ABANDONED_CART
}

enum CampaignStatus {
  ACTIVE
  PAUSED
}

enum MessageChannel {
  EMAIL
}

enum EnrollmentStatus {
  ACTIVE
  CONVERTED
  HALTED
  COMPLETED
}

enum CampaignSendStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  BLOCKED
  FAILED
  DELAYED
}

enum SuppressionReason {
  UNSUBSCRIBE
  BOUNCE
  COMPLAINT
  MANUAL
}

model MessageTemplate {
  id             String         @id @default(cuid())
  organizationId String
  key            String
  version        Int            @default(1)
  channel        MessageChannel @default(EMAIL)
  name           String
  subject        String
  bodyHtml       String
  bodyText       String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps        CampaignStep[]

  @@unique([organizationId, key, version])
}

model Campaign {
  id                       String         @id @default(cuid())
  organizationId           String
  name                     String
  type                     CampaignType   @default(ABANDONED_CART)
  status                   CampaignStatus @default(ACTIVE)
  channel                  MessageChannel @default(EMAIL)
  /** Attribution window (minutes) for crediting a recovery. Default 7 days. */
  attributionWindowMinutes Int            @default(10080)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  deletedAt                DateTime?

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps        CampaignStep[]
  enrollments  CampaignEnrollment[]

  @@index([organizationId, type, status])
}

model CampaignStep {
  id          String @id @default(cuid())
  campaignId  String
  stepOrder   Int
  /** T+delay from checkoutStartedAt: 60 / 1440 / 4320. */
  delayMinutes Int
  templateId  String

  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  template MessageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sends    CampaignSend[]

  @@unique([campaignId, stepOrder])
}

model CampaignEnrollment {
  id                String           @id @default(cuid())
  organizationId    String
  campaignId        String
  cartId            String
  customerId        String
  email             String
  status            EnrollmentStatus @default(ACTIVE)
  checkoutStartedAt DateTime
  enrolledAt        DateTime         @default(now())
  convertedOrderId  String?
  convertedAt       DateTime?
  haltedAt          DateTime?
  haltReason        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sends        CampaignSend[]

  // Idempotent enrollment: the same cart is never enrolled twice.
  @@unique([campaignId, cartId])
  @@index([organizationId, status])
}

model CampaignSend {
  id              String             @id @default(cuid())
  organizationId  String
  enrollmentId    String
  campaignStepId  String
  channel         MessageChannel     @default(EMAIL)
  templateVersion Int
  status          CampaignSendStatus @default(QUEUED)
  providerMessageId String?
  blockedReason   String?
  sentAt          DateTime?
  outcomeAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollment   CampaignEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step         CampaignStep       @relation(fields: [campaignStepId], references: [id], onDelete: Cascade)

  // One send per step per enrollment (idempotent send).
  @@unique([enrollmentId, campaignStepId])
  @@index([organizationId, status])
  @@index([providerMessageId])
}

model Suppression {
  id             String            @id @default(cuid())
  organizationId String
  email          String
  reason         SuppressionReason
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, email])
}

// ============================================================================
// P2.3 — Meta ads + first-touch attribution + audience sync.
// Every ad entity carries organizationId + externalId with UNIQUE(org,externalId)
// for idempotent upserts. Money is integer minor units (paise); time is UTC.
// ============================================================================

/** Which node of the Meta hierarchy an AdMetricDaily row rolls up. */
enum AdEntityType {
  campaign
  adset
  ad
  creative
}

/** A Meta ad account (the connected surface). */
model AdAccount {
  id             String   @id @default(cuid())
  organizationId String
  externalId     String // act_<id>
  name           String
  currency       String   @default("INR")
  status         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId])
  @@index([organizationId])
}

model AdCampaign {
  id                String   @id @default(cuid())
  organizationId    String
  externalId        String
  accountExternalId String?
  name              String
  status            String?
  objective         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId])
  @@index([organizationId])
}

model AdSet {
  id                 String   @id @default(cuid())
  organizationId     String
  externalId         String
  campaignExternalId String?
  name               String
  status             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId])
  @@index([organizationId])
}

model Ad {
  id                 String   @id @default(cuid())
  organizationId     String
  externalId         String
  adsetExternalId    String?
  creativeExternalId String?
  name               String
  status             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId])
  @@index([organizationId])
}

model AdCreative {
  id             String   @id @default(cuid())
  organizationId String
  externalId     String
  name           String
  thumbnailUrl   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId])
  @@index([organizationId])
}

/** Daily rollup per entity. UNIQUE(org, entityType, entityId, date) makes a
 * re-pull of a day OVERWRITE (idempotent), never duplicate. */
model AdMetricDaily {
  id             String       @id @default(cuid())
  organizationId String
  entityType     AdEntityType
  entityId       String // the entity's Meta externalId
  date           DateTime     @db.Date
  spendMinor     Int          @default(0)
  impressions    Int          @default(0)
  clicks         Int          @default(0)
  conversions    Int          @default(0) // Meta-REPORTED (over-reports; see glossary)
  currency       String       @default("INR")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, entityType, entityId, date])
  @@index([organizationId, entityType, date])
}

/** EVERY touchpoint (Part 9). We bucket acquisition on the FIRST-touch source
 * but keep every one. Web touchpoints ride in via order cart attributes; Meta
 * touchpoints come from Lead-Ads. UNIQUE(org, channel, sessionId) dedups. */
model Touchpoint {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String?
  sessionId      String // order externalId (web) or lead externalId (meta)
  channel        String // "web" | "meta" | ...
  source         String // utm_source / "meta" / "unknown"
  campaign       String?
  adset          String?
  creative       String?
  utm            Json?
  occurredAt     DateTime
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, channel, sessionId])
  @@index([organizationId, customerId, occurredAt])
  @@index([organizationId, source])
}

/** Meta Lead-Ads submission, first-touch attributed. Distinct from the CRM
 * `Lead` (which converts to a Contact) — an AdLead converts to a Customer. */
enum AdLeadStatus {
  NEW
  CONVERTED
}

model AdLead {
  id                     String       @id @default(cuid())
  organizationId         String
  externalId             String // Meta leadgen id
  formId                 String?
  name                   String?
  email                  String?
  phone                  String?
  source                 String       @default("meta")
  campaign               String?
  adset                  String?
  ad                     String?
  firstTouchTouchpointId String?
  status                 AdLeadStatus @default(NEW)
  convertedCustomerId    String?
  occurredAt             DateTime
  createdAt              DateTime     @default(now())
  updatedAt             DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId])
  @@index([organizationId, email])
  @@index([organizationId, status])
}

/** Audit of every segment→Meta audience push. */
enum AudienceType {
  custom
  suppression
}

model AudienceSync {
  id                String       @id @default(cuid())
  organizationId    String
  segmentId         String
  metaAudienceId    String?
  type              AudienceType @default(custom)
  sizeSynced        Int          @default(0)
  excludedByConsent Int          @default(0)
  lastSyncedAt      DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, segmentId])
}

// ============================================================================
// Loyalty ledger + threshold incentive engine.
// ============================================================================

/** Ledger reasons. EARN/CLAWBACK correct an order's earned points (the ledger
 * converges to floor(net ÷ divisor)); BURN spends points; ADJUST is manual. */
enum LoyaltyReason {
  EARN
  BURN
  CLAWBACK
  ADJUST
}

/**
 * APPEND-ONLY loyalty ledger. Balance is SUM(delta) — never a mutable field.
 * Earn on paid/fulfilled orders, burn on redemption, negative CLAWBACK on refund.
 * Rows are never edited or deleted.
 */
model LoyaltyTransaction {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String
  delta          Int // earn +, burn/clawback −
  reason         LoyaltyReason
  refOrderId     String? // the order this earn/clawback/burn relates to
  note           String?
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, customerId, createdAt])
  @@index([organizationId, refOrderId])
}

enum DiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum IncentiveStatus {
  ACTIVE
  REDEEMED
  EXPIRED
}

/**
 * A threshold-triggered store discount. The VALUE is capped (maxValueMinor, not
 * just a %), low-margin SKUs are excluded, a minimum next-order value is set, and
 * a validity window bounds it. Redemption is tracked (redeemedOrderId, set once);
 * a refund of the sourceOrder reverses it. State the numbers before storing.
 */
model Incentive {
  id                String          @id @default(cuid())
  organizationId    String
  customerId        String
  /** { metric: units|orders|distinct_skus, threshold, windowDays? } — precise. */
  triggerRule       Json
  discountType      DiscountType    @default(FIXED_AMOUNT)
  discountValueMinor Int? // FIXED_AMOUNT: the amount off (already capped)
  discountPercent   Int? // PERCENT: the percentage
  maxValueMinor     Int // the VALUE cap (paise)
  minNextOrderMinor Int             @default(0)
  /** { productExternalIds: string[] } — low-margin SKUs excluded from the code. */
  excludedSkuRule   Json?
  /** Loyalty points spent to redeem (0 for free threshold rewards). */
  pointsCost        Int             @default(0)
  /** Whether the margin guard was ON when issued (honest audit of exposure). */
  marginGuard       Boolean         @default(true)
  discountCode      String?
  validFrom         DateTime
  validUntil        DateTime
  status            IncentiveStatus @default(ACTIVE)
  sourceOrderId     String? // the qualifying order
  redeemedOrderId   String? // set once, when a matching order lands
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, customerId])
  @@index([organizationId, status, validUntil])
  @@index([organizationId, discountCode])
}
