# ---- apps/web environment ----

# Clerk (frontend). Publishable key is safe to expose.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk redirect URLs (defaults work for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Base URL of the NestJS API (no trailing slash). Every API call in
# src/lib/api.ts reads this one var — never hardcode the host/port elsewhere.
#   Local:      http://localhost:4000  (matches apps/api PORT=4000)
#   Production: https://<your-api>.up.railway.app  (the deployed API domain)
# The API must also list this app's web origin in CORS_ORIGINS.
NEXT_PUBLIC_API_URL=http://localhost:4000
